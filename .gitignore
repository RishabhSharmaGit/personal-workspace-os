# secrets
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db
desktop.ini

# Bun / Node
node_modules/
*.log
bun.lockb
# bun.lock (text lockfile, Bun >=1.2) IS committed intentionally — keep tracked.

# Supabase local
db/supabase/.temp/
db/supabase/.branches/

# Claude Code personal overrides
.claude/settings.local.json
.mcp.json

# Local indexer cache
scripts/.cache/

# Obsidian vault state (per-user, volatile)
.obsidian/
**/.obsidian/

# Personal input — the SINGLE canonical home for everything personal (gitignored content,
# committed structure). Holds raw source artifacts (resumes, profile/IG/chat exports, JDs
# under references/jds/) AND sensitive structured data under personal/private/ (comp,
# contacts). Content is gitignored; only README.md + per-subfolder .gitkeep are tracked.
# See personal/README.md for the layout contract.
personal/**
!personal/README.md
!personal/*/
!personal/*/.gitkeep

# Defensive safety nets — the canonical home is repo-root personal/ (above); do NOT create
# per-workspace private/ or personal/ folders. These rules remain so that IF sensitive data
# ever lands in a workspace by accident, git still refuses to track it.
#   workspaces/*/private/  — salary, ESOPs, vesting, family, medical, contacts, etc.
#   workspaces/*/personal/ — raw artifacts (JDs, resume PDFs, LinkedIn/chat exports)
workspaces/*/private/
workspaces/*/personal/

# Generated resume artifacts — regenerate from .resume.json via
# workspaces/career-os/resumes/RENDERING.md. The master sources (.json/.md) are tracked.
workspaces/career-os/resumes/**/*.pdf
workspaces/career-os/resumes/**/*.rendered.html

# Job-application specifics stay LOCAL ONLY — this repo is PUBLIC and is reachable from the
# GitHub profile linked on the resume. The companies/roles being targeted, tailored resume
# variants, cover letters, and per-application trackers must never be committed. Only derived,
# abstracted knowledge (skills to master, decisions, research, generic keyword sets) is tracked.
# Folder structure is preserved via .gitkeep; the variants/ workflow README stays tracked.
workspaces/career-os/applications/*
!workspaces/career-os/applications/.gitkeep
workspaces/career-os/cover-letters/*
!workspaces/career-os/cover-letters/.gitkeep
workspaces/career-os/roles/*
!workspaces/career-os/roles/.gitkeep
workspaces/career-os/resumes/variants/*
!workspaces/career-os/resumes/variants/README.md

# Per-company interview prep names a target company — keep LOCAL ONLY (repo is public).
# The generic, company-agnostic interview-prep/common.md stays tracked.
workspaces/career-os/interview-prep/*/

