# secrets
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db
desktop.ini

# Bun / Node
node_modules/
*.log
bun.lockb
# bun.lock (text lockfile, Bun >=1.2) IS committed intentionally — keep tracked.

# Supabase local
db/supabase/.temp/
db/supabase/.branches/

# Claude Code personal overrides
.claude/settings.local.json
.mcp.json

# Local indexer cache
scripts/.cache/

# Obsidian vault state (per-user, volatile)
.obsidian/
**/.obsidian/

# Personal source artifacts — content gitignored, structure committed.
# See personal/README.md for the layout contract.
personal/**
!personal/README.md
!personal/*/
!personal/*/.gitkeep

# Sensitive workspace content (salary, ESOPs, vesting, family, medical, etc.)
# Any folder named "private/" inside any workspace is fully gitignored.
workspaces/*/private/

# Generated resume artifacts — regenerate from .resume.json via
# workspaces/career-os/resumes/RENDERING.md. Sources (.json/.md) are tracked.
workspaces/career-os/resumes/**/*.pdf
workspaces/career-os/resumes/**/*.rendered.html

